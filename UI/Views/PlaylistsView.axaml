<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AudioStemPlayer.UI.Views.PlaylistsView"
             x:CompileBindings="False"
             Background="{DynamicResource WindowBackgroundBrush}"
             DragDrop.AllowDrop="True">

    <Grid RowDefinitions="Auto, Auto, *">
        <Grid Grid.Row="0" Margin="0" Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Playlists"
                       VerticalAlignment="Center"
                       Margin="20,20,0,20"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="Helvetica Bold"
                       FontSize="22"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10" Margin="0,5,10,5">
                <Button Content="New Playlist" Classes="primary" Command="{Binding CreatePlaylistCommand}" Padding="15,5"/>
                <Button Content="Delete" IsEnabled="{Binding HasSelectedPlaylist}" Classes="danger" Command="{Binding DeletePlaylistCommand}" Padding="15,5"/>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource SeparatorBrush}" HorizontalAlignment="Stretch"/>

        <Grid Grid.Row="2" ColumnDefinitions="2*, 3*" Margin="20,10,20,20">

            <Border Grid.Column="0"
                    Background="{DynamicResource TabsBackgroundBrush}"
                    CornerRadius="6"
                    Padding="5"
                    Margin="0,0,10,0">
                <ListBox ItemsSource="{Binding Playlists}"
                         SelectedItem="{Binding SelectedPlaylist}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="{Binding TrackCountText}"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            
            <Border Grid.Column="1"
                    Background="{DynamicResource TabsBackgroundBrush}"
                    CornerRadius="6"
                    Padding="15">
                <ScrollViewer>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Select a playlist to view tracks"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontStyle="Italic"
                                   IsVisible="{Binding !HasSelectedPlaylist}"/>

                        <TextBlock Text="{Binding SelectedPlaylist.Name}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   IsVisible="{Binding HasSelectedPlaylist}"/>

                        <ItemsControl ItemsSource="{Binding PlaylistTracks}"
                                      IsVisible="{Binding HasSelectedPlaylist}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Button Content="Play"
                                                Classes="primary"
                                                Command="{Binding $parent[UserControl].DataContext.PlayTrackCommand}"
                                                CommandParameter="{Binding .}"
                                                Padding="8,3"
                                                Margin="0,0,10,0"/>
                                        <Button Content="Remove"
                                                Classes="danger"
                                                Command="{Binding $parent[UserControl].DataContext.RemoveTrackFromPlaylistCommand}"
                                                CommandParameter="{Binding .}"
                                                Padding="8,3"
                                                Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>