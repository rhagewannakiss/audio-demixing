<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioStemPlayer.UI.ViewModels"
             x:Class="AudioStemPlayer.UI.Views.LibraryView"
             x:DataType="vm:LibraryViewModel"
             Background="{DynamicResource WindowBackgroundBrush}">

    <Grid RowDefinitions="Auto, Auto, *">
        <Grid Grid.Row="0"
              Margin="0"
              Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="Audio Library"
                       VerticalAlignment="Center"
                       Margin="20,20,0,20"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="Helvetica Bold"
                       FontSize="22"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="0,5,10,5">
                
                <TextBlock Text="Search track:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
                
                <TextBox Text="{Binding SearchText}"
                         Watermark="Start typing"
                         MinWidth="200"
                         VerticalAlignment="Center"/>
                
                <Button Content="Load Track"
                        Classes="primary"
                        Command="{Binding LoadTrackCommand}"
                        Padding="15,5"/>
                
                <Button Content="Delete Track"
                        Classes="danger"
                        Command="{Binding DeleteTrackCommand}"
                        Padding="15,5"/>
            </StackPanel>
        </Grid>
        
        <Rectangle Grid.Row="1"
                   Height="1"
                   Fill="{DynamicResource SeparatorBrush}"
                   HorizontalAlignment="Stretch" />
        
        <Grid Grid.Row="2"
              RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,90"
                  Margin="10,8,20,4">
                <TextBlock Grid.Column="0"
                           Text="Track"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="Bold"/>
                <TextBlock Grid.Column="1"
                           Text="Duration"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Tracks}"
                     SelectedItem="{Binding SelectedTrack}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,90"
                              Margin="10,5">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       Foreground="{DynamicResource TextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DurationText}"
                                       Foreground="{DynamicResource TextBrush}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
