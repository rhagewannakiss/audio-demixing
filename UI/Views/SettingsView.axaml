<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioStemPlayer.UI.ViewModels"
             x:Class="AudioStemPlayer.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"/>
        <Button Content="Reset application" 
                Classes="danger"
                Command="{Binding ResetApplicationCommand}"
                HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>