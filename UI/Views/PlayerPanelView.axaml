<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AudioStemPlayer.UI.ViewModels"
             x:Class="AudioStemPlayer.UI.Views.PlayerPanelView"
             x:DataType="vm:PlayerPanelViewModel">
    <UserControl.Styles>
        <Style Selector="Slider.ModernSlider /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Ellipse Fill="{TemplateBinding Background}"
                             Stroke="White"
                             StrokeThickness="2"/>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Slider.ModernSlider /template/ Thumb:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
        </Style>

        <Style Selector="Slider.ModernSlider /template/ Thumb:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
        </Style>

        <Style Selector="Button:disabled PathIcon">
            <Setter Property="Foreground" Value="#888888"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="5" Margin="10">
        
        <Border Background="{DynamicResource SeparatorBrush}"
                CornerRadius="8"
                HorizontalAlignment="Center"
                Width="300" Height="300"
                Margin="0,0,0,5">
            <Panel>
                <Border CornerRadius="8" ClipToBounds="True"
                        Width="300" Height="300"
                        IsVisible="{Binding HasCover}">
                    <Image Source="{Binding CoverBitmap}"
                           Stretch="UniformToFill"
                           Width="300" Height="300"/>
                </Border>
                <Viewbox Stretch="Uniform" MaxWidth="100" MaxHeight="100"
                         IsVisible="{Binding HasNoCover}">
                    <TextBlock Text="♫"
                               FontSize="80"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Viewbox>
            </Panel>
        </Border>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,5">
            <TextBlock Text="{Binding TrackTitle}"
                       FontSize="24"
                       Foreground="{DynamicResource TextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="10,0"/>
            <TextBlock Text="{Binding TrackArtist}"
                       FontSize="16"
                       Foreground="{DynamicResource TextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="10,5,10,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6" Margin="0,10">
            <Button Command="{Binding PreviousCommand}" 
                    IsEnabled="{Binding HasPreviousTrack}"
                    Width="42" Height="34" Padding="0"
                    Classes="primary">
                <PathIcon Data="M 2 4 L 3 4 L 3 12 L 2 12 Z M 4 8 L 8 4 L 8 12 Z M 9 8 L 13 4 L 13 12 Z"
                          Width="16" Height="16"/>
            </Button>

            <Button Command="{Binding PlayPauseCommand}" 
                    IsEnabled="{Binding IsLoaded}"
                    Width="42" Height="34" Padding="0"
                    Classes="primary">
                <Panel>
                    <PathIcon Data="M 8 6 L 20 12 L 8 18 Z"
                              Width="16" Height="16"
                              IsVisible="{Binding IsNotPlaying}"/>
                    <PathIcon Data="M 8 6 L 13 6 L 13 18 L 8 18 Z M 15 6 L 20 6 L 20 18 L 15 18 Z"
                              Width="16" Height="16"
                              IsVisible="{Binding IsPlaying}"/>
                </Panel>
            </Button>

            <Button Command="{Binding NextCommand}" 
                    IsEnabled="{Binding HasNextTrack}"
                    Width="42" Height="34" Padding="0"
                    Classes="primary">
                <PathIcon Data="M 13 4 L 14 4 L 14 12 L 13 12 Z M 12 8 L 8 4 L 8 12 Z M 7 8 L 3 4 L 3 12 Z"
                          Width="16" Height="16"/>
            </Button>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
            <TextBlock Text="{Binding CurrentTime}" Width="40" TextAlignment="Center"/>
            <Slider Classes="ModernSlider"
                    Minimum="0" Maximum="1" 
                    Value="{Binding Position}" 
                    Width="200"
                    Background="{DynamicResource SeparatorBrush}"
                    Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Text="{Binding TotalTime}" Width="40" TextAlignment="Center"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
            <TextBlock Text="Volume:" VerticalAlignment="Center"/>
            <Slider Classes="ModernSlider"
                    Minimum="0" Maximum="100" 
                    Value="{Binding Volume}" 
                    Width="150"
                    Background="{DynamicResource SeparatorBrush}"
                    Foreground="{DynamicResource AccentBrush}"/>
        </StackPanel>
    </StackPanel>
</UserControl>