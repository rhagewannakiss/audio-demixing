<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AudioStemPlayer.UI.ViewModels"
             x:Class="AudioStemPlayer.UI.Views.PlayerPanelView"
             x:DataType="vm:PlayerPanelViewModel">
    <UserControl.Styles>
        <Style Selector="Slider.ModernSlider /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Ellipse Fill="{TemplateBinding Background}"
                             Stroke="White"
                             StrokeThickness="2"/>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Slider.ModernSlider /template/ Thumb:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
        </Style>

        <Style Selector="Slider.ModernSlider /template/ Thumb:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="10" Margin="10">

    <Border Background="{DynamicResource SeparatorBrush}"
            CornerRadius="8"
            HorizontalAlignment="Center"
            Width="300" Height="300"
            Margin="0,0,0,5">
        <Panel>
            <Border CornerRadius="8" ClipToBounds="True"
                    Width="300" Height="300"
                    IsVisible="{Binding HasCover}">
                <Image Source="{Binding CoverBitmap}"
                       Stretch="UniformToFill"
                       Width="300" Height="300"/>
            </Border>
            <Viewbox Stretch="Uniform" MaxWidth="100" MaxHeight="100"
                     IsVisible="{Binding HasNoCover}">
                <TextBlock Text="♫"
                           FontSize="80"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Viewbox>
        </Panel>
    </Border>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,5">
            <TextBlock Text="{Binding TrackTitle}"
                       FontSize="24"
                       Foreground="{DynamicResource TextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="10,0"/>
            <TextBlock Text="{Binding TrackArtist}"
                       FontSize="16"
                       Foreground="{DynamicResource TextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="10,5,10,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10">
            <Button Content="Play" Command="{Binding PlayCommand}" 
                    IsEnabled="{Binding IsLoaded}"/>
            <Button Content="Pause" Command="{Binding PauseCommand}" 
                    IsEnabled="{Binding IsPlaying}"/>
            <Button Content="Stop" Command="{Binding StopCommand}" 
                    IsEnabled="{Binding IsLoaded}"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Margin="0,5">
            <TextBlock Text="{Binding CurrentTime}" Width="40" TextAlignment="Center"/>
            <Slider Classes="ModernSlider"
                    Minimum="0" Maximum="1" 
                    Value="{Binding Position}" 
                    Width="200"
                    Background="{DynamicResource SeparatorBrush}"
                    Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Text="{Binding TotalTime}" Width="40" TextAlignment="Center"/>
        </StackPanel>
        
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Margin="0,5">
            <TextBlock Text="Volume:" VerticalAlignment="Center"/>
            <Slider Classes="ModernSlider"
                    Minimum="0" Maximum="100" 
                    Value="{Binding Volume}" 
                    Width="150"
                    Background="{DynamicResource SeparatorBrush}"
                    Foreground="{DynamicResource AccentBrush}"/>
        </StackPanel>
    </StackPanel>
</UserControl>