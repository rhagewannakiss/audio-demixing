<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioStemPlayer.UI.ViewModels"
             xmlns:converters="clr-namespace:AudioStemPlayer.UI.Converters"
             x:Class="AudioStemPlayer.UI.Views.HistoryView"
             x:DataType="vm:HistoryViewModel"
             x:CompileBindings="False"
             Background="{DynamicResource WindowBackgroundBrush}">

    <UserControl.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, Auto, *">

        <Grid Grid.Row="0" Margin="0" Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Processing History"
                       VerticalAlignment="Center"
                       Margin="20,20,0,20"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="Helvetica Bold"
                       FontSize="22"/>
        </Grid>
        
        
        
        <Rectangle Grid.Row="1"
                   Height="1"
                   Fill="{DynamicResource SeparatorBrush}"
                   HorizontalAlignment="Stretch"/>
        
        <Grid Grid.Row="2" ColumnDefinitions="2*, 3*" Margin="20,10,20,20">
            <Border Grid.Column="0"
                    Background="{DynamicResource TabsBackgroundBrush}"
                    CornerRadius="6"
                    Padding="5"
                    Margin="0,0,10,0">
                <ListBox ItemsSource="{Binding Jobs}"
                         SelectedItem="{Binding SelectedJob}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='\{0:g\}'}"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            
            <Border Grid.Column="1"
                    Background="{DynamicResource TabsBackgroundBrush}"
                    CornerRadius="6"
                    Padding="15">
                <ScrollViewer>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Select a job to see details"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontStyle="Italic"
                                   IsVisible="{Binding !HasSelectedJob}"/>

                        <StackPanel Spacing="10" IsVisible="{Binding HasSelectedJob}">
                            <TextBlock Text="Job Details" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="{Binding SelectedJob.InputFilePath}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Status: " Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="{Binding SelectedJob.Status}"
                                           Foreground="{Binding SelectedJob.Status, Converter={StaticResource StatusToBrushConverter}}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedJob.CreatedAt, StringFormat='Created: {0:g}'}" Foreground="{DynamicResource TextBrush}"/>

                            <Button Content="Play Original File"
                                    Classes="primary"
                                    Command="{Binding PlayOriginalCommand}"
                                    CommandParameter="{Binding SelectedJob}"
                                    Margin="0,5"/>

                            <StackPanel IsVisible="{Binding SelectedJob.IsSucceeded}">
                                <TextBlock Text="Stems:" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,5,0,0"/>
                                <ItemsControl ItemsSource="{Binding SelectedJobStems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <Button Content="Play"
                                                        Classes="primary"
                                                        Command="{Binding $parent[UserControl].DataContext.PlayStemCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Padding="8,3"
                                                        Margin="0,0,10,0"/>
                                                <Button Content="Save"
                                                        Classes="primary"
                                                        Command="{Binding $parent[UserControl].DataContext.SaveStemCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Padding="8,3"
                                                        Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding StemType}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>