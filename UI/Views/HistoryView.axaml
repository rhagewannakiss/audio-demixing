<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AudioStemPlayer.UI.ViewModels"
             x:Class="AudioStemPlayer.UI.Views.HistoryView"
             x:DataType="vm:HistoryViewModel"
             Background="{DynamicResource WindowBackgroundBrush}">

    <Grid RowDefinitions="Auto, Auto, *">
        <Grid Grid.Row="0"
              Margin="0"
              Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="History"
                       VerticalAlignment="Center"
                       Margin="20,20,0,20"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="Helvetica Bold"
                       FontSize="22"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="0,5,10,5">
                
                <Button Content="Clear History"
                        Classes="primary"
                        Command="{Binding ClearHistoryCommand}"
                        Padding="15,5"/>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="1"
                   Height="1"
                   Fill="{DynamicResource SeparatorBrush}"
                   HorizontalAlignment="Stretch" />

        <StackPanel Grid.Row="2" Margin="20,10,20,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,10"
                       FontStyle="Italic"/>

            <ListBox ItemsSource="{Binding HistoryItems}"
                     Background="Transparent"
                     BorderThickness="0"
                     MinHeight="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="10,5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</UserControl>