<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AudioStemPlayer.UI.ViewModels"
        x:Class="AudioStemPlayer.UI.Views.PlaylistPickerDialog"
        Title="Select Playlist"
        Width="350" Height="350"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        x:CompileBindings="False">

    <Grid RowDefinitions="*, Auto" Margin="15">
        <ListBox Grid.Row="0" ItemsSource="{Binding Playlists}"
                 SelectedItem="{Binding SelectedPlaylist}"
                 Background="{DynamicResource TabsBackgroundBrush}"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextBrush}" Margin="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Content="Add" Classes="primary" Command="{Binding SelectCommand}"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>